<view class="home-page">
  <view class="top-white">
    <view class="status-row">
      <view class="menu-button"><view></view><view></view><view></view></view>
      <view class="mini-capsule"><text>...</text><view class="capsule-divider"></view><view class="capsule-circle"></view></view>
    </view>
    <view class="brand-logo">
      <text class="brand-small">{{brand.en}}</text>
      <text class="brand-main">{{brand.main}}</text>
      <text class="brand-cn">{{brand.cn}}</text>
    </view>
  </view>

  <view class="content-wrap">
    <view class="main-card">
      <view class="promo-banner">
        <view class="banner-shape slide"></view>
        <view class="banner-shape cloud cloud-one"></view>
        <view class="banner-shape cloud cloud-two"></view>
        <view class="mascot mascot-left"><view class="mascot-face">乐</view></view>
        <view class="mascot mascot-right"><view class="mascot-face green-face">玩</view></view>
        <view class="ball-pit"><view class="ball ball-a"></view><view class="ball ball-b"></view><view class="ball ball-c"></view><view class="ball ball-d"></view></view>
        <view class="banner-copy">
          <text class="banner-title">吃喝玩乐 一票双享</text>
          <view class="price-row"><view class="price-pill">¥388 儿童票</view><view class="price-pill">¥198 成人票</view></view>
        </view>
      </view>

      <view class="entry-grid">
        <view class="entry-item" wx:for="{{entries}}" wx:key="label">
          <view class="entry-avatar {{item.className}}"><view class="avatar-glow"></view><text>{{item.icon}}</text></view>
          <text class="entry-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="store-section">
      <view class="bg-flower flower-one"></view><view class="bg-flower flower-two"></view><view class="bg-dot dot-one"></view><view class="bg-dot dot-two"></view>
      <text class="section-title">门店介绍</text>
      <view class="store-card">
        <view class="video-cover">
          <view class="store-sky"></view>
          <view class="store-building"><view class="store-sign">HAPPY PLAYTIME</view><view class="store-glass"></view><view class="store-door"></view></view>
          <view class="outdoor-balloon orange-balloon"></view><view class="outdoor-balloon green-balloon"></view>
          <view class="play-button"><view class="play-triangle"></view></view>
        </view>
        <view class="store-info">
          <view><text class="store-name">欢乐时光主题乐园</text><view class="store-address">阳光市中心广场3楼</view></view>
          <view class="score">星 4.9</view>
        </view>
      </view>
    </view>
  </view>

  <view class="tabbar">
    <view class="tab-item active"><view class="tab-icon home"></view><text>首页</text></view>
    <view class="tab-item"><view class="tab-icon shop"></view><text>商品</text></view>
    <view class="tab-item"><view class="tab-icon mine"></view><text>我的</text></view>
  </view>
</view>
