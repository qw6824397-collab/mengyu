.home-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding-bottom: 140rpx;
  background:
    radial-gradient(circle at 12% 33%, rgba(255, 205, 41, .26) 0 74rpx, transparent 78rpx),
    radial-gradient(circle at 84% 50%, rgba(255, 205, 41, .24) 0 88rpx, transparent 92rpx),
    radial-gradient(circle at 22% 78%, rgba(255, 255, 255, .12) 0 96rpx, transparent 100rpx),
    linear-gradient(180deg, #ffffff 0 230rpx, #ff7900 230rpx 100%);
  color: #141414;
}

.top-white {
  position: relative;
  height: 218rpx;
  background: #ffffff;
  border-bottom-left-radius: 44rpx;
  border-bottom-right-radius: 44rpx;
  z-index: 2;
}

.brand-logo {
  position: absolute;
  left: 0;
  right: 0;
  top: 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1;
}

.brand-small {
  font-size: 18rpx;
  font-weight: 900;
  color: #ff7b1a;
  letter-spacing: 2rpx;
}

.brand-main {
  margin-top: 2rpx;
  font-size: 48rpx;
  font-weight: 900;
  color: #10aee8;
  letter-spacing: 1rpx;
}

.brand-cn {
  margin-top: 6rpx;
  font-size: 21rpx;
  font-weight: 900;
  color: #10aee8;
}

.content-wrap {
  position: relative;
  z-index: 4;
  margin-top: -28rpx;
  padding: 0 30rpx;
}

.main-card {
  padding: 24rpx 22rpx 30rpx;
  background: #ffffff;
  border-radius: 36rpx;
  box-shadow: 0 18rpx 42rpx rgba(151, 67, 0, .18);
}

.promo-banner {
  position: relative;
  height: 246rpx;
  overflow: hidden;
  border-radius: 26rpx;
  background: linear-gradient(135deg, #ff8b12 0%, #ffc634 47%, #ffe35a 100%);
}

.banner-copy {
  position: absolute;
  z-index: 6;
  left: 0;
  right: 0;
  top: 68rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.banner-title {
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 900;
  text-shadow: 0 5rpx 10rpx rgba(171, 76, 0, .35);
}

.price-row {
  margin-top: 30rpx;
  display: flex;
  gap: 22rpx;
}

.price-pill {
  min-width: 172rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 26rpx;
  color: #ffffff;
  background: linear-gradient(180deg, #8dda31, #30b834);
  font-size: 22rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 0 rgba(35, 130, 32, .24);
}

.banner-shape {
  position: absolute;
  opacity: .92;
}

.slide {
  width: 340rpx;
  height: 80rpx;
  left: -20rpx;
  top: 22rpx;
  border-radius: 64rpx;
  transform: rotate(-24deg);
  background: repeating-linear-gradient(90deg, #e94a43 0 42rpx, #ff9f1c 42rpx 84rpx, #28c76f 84rpx 126rpx, #22a6f2 126rpx 168rpx, #b65cff 168rpx 210rpx);
}

.cloud {
  border-radius: 50%;
  background: rgba(255, 255, 255, .55);
}

.cloud-one {
  width: 110rpx;
  height: 110rpx;
  right: 52rpx;
  top: 32rpx;
}

.cloud-two {
  width: 72rpx;
  height: 72rpx;
  right: 154rpx;
  top: 64rpx;
}

.mascot {
  position: absolute;
  z-index: 4;
  bottom: 16rpx;
  width: 108rpx;
  height: 122rpx;
  border-radius: 58rpx 58rpx 44rpx 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 18rpx rgba(142, 75, 0, .18);
}

.mascot-left {
  left: 24rpx;
  background: #2fc5ff;
  transform: rotate(-8deg);
}

.mascot-right {
  right: 24rpx;
  background: #5bd34f;
  transform: rotate(8deg);
}

.mascot-face {
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #ff7a00;
  font-size: 34rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.green-face {
  color: #26b943;
}

.ball-pit {
  position: absolute;
  left: 44rpx;
  right: 44rpx;
  bottom: -18rpx;
  height: 70rpx;
  border-radius: 50%;
  background: rgba(255, 152, 0, .45);
}

.ball {
  position: absolute;
  width: 23rpx;
  height: 23rpx;
  border-radius: 50%;
}

.ball-a { left: 222rpx; top: 14rpx; background: #0bb9ff; }
.ball-b { left: 276rpx; top: 24rpx; background: #f54656; }
.ball-c { right: 216rpx; top: 12rpx; background: #6ccf3a; }
.ball-d { right: 164rpx; top: 28rpx; background: #7655ff; }

.entry-grid {
  padding: 34rpx 0 0;
  display: flex;
  justify-content: space-between;
}

.entry-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.entry-avatar {
  position: relative;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 900;
  box-shadow: 0 9rpx 18rpx rgba(0, 0, 0, .16);
  overflow: hidden;
}

.entry-avatar::before {
  content: '';
  position: absolute;
  width: 62rpx;
  height: 62rpx;
  left: 13rpx;
  top: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, .38);
}

.entry-avatar::after {
  content: '';
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  bottom: 14rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, .10);
}

.entry-avatar text {
  position: relative;
  z-index: 2;
}

.entry-ticket { background: linear-gradient(145deg, #ffd500, #ff9200); }
.entry-booking { background: linear-gradient(145deg, #20ceff, #0a7fe0); }
.entry-activity { background: linear-gradient(145deg, #ff9e31, #ff6600); }
.entry-scan { background: linear-gradient(145deg, #35e672, #10aa4a); }

.entry-label {
  margin-top: 16rpx;
  color: #202020;
  font-size: 24rpx;
  font-weight: 800;
}

.store-section {
  position: relative;
  margin: 34rpx -30rpx 0;
  padding: 0 30rpx 30rpx;
  min-height: 500rpx;
}

.section-title {
  position: relative;
  z-index: 2;
  display: block;
  margin: 6rpx 0 20rpx;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 900;
}

.bg-flower,
.bg-dot {
  position: absolute;
  opacity: .16;
  border-radius: 50%;
}

.bg-flower {
  width: 118rpx;
  height: 118rpx;
  border: 18rpx solid rgba(255,255,255,.45);
}

.flower-one { right: 40rpx; top: 18rpx; }
.flower-two { left: -36rpx; bottom: 90rpx; }
.bg-dot { background: rgba(255,255,255,.44); }
.dot-one { width: 36rpx; height: 36rpx; left: 220rpx; top: 86rpx; }
.dot-two { width: 26rpx; height: 26rpx; right: 185rpx; top: 206rpx; }

.store-card {
  position: relative;
  z-index: 2;
  overflow: hidden;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(126, 44, 0, .18);
}

.video-cover {
  position: relative;
  height: 300rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #cdefff 0%, #fff4c7 48%, #f4b36b 100%);
}

.store-sky {
  position: absolute;
  left: -86rpx;
  top: -120rpx;
  width: 470rpx;
  height: 470rpx;
  border-radius: 50%;
  background: rgba(255,255,255,.38);
}

.store-building {
  position: absolute;
  left: 62rpx;
  right: 62rpx;
  bottom: 34rpx;
  height: 168rpx;
  border-radius: 26rpx 26rpx 8rpx 8rpx;
  background: linear-gradient(180deg, #f4cf8a, #c98c49);
  box-shadow: 0 -12rpx 0 rgba(255,255,255,.35) inset;
}

.store-sign {
  position: absolute;
  left: 48rpx;
  right: 48rpx;
  top: 22rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: #ffffff;
  color: #12aee8;
  font-size: 20rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.store-glass {
  position: absolute;
  left: 52rpx;
  right: 52rpx;
  bottom: 18rpx;
  height: 74rpx;
  border-radius: 14rpx;
  background: rgba(60, 196, 255, .48);
}

.store-door {
  position: absolute;
  left: 50%;
  bottom: 18rpx;
  width: 58rpx;
  height: 74rpx;
  margin-left: -29rpx;
  background: rgba(255,255,255,.50);
}

.outdoor-balloon {
  position: absolute;
  border-radius: 50%;
  opacity: .95;
}

.orange-balloon {
  width: 126rpx;
  height: 176rpx;
  left: 34rpx;
  top: 44rpx;
  background: #ff6d1b;
  transform: rotate(-16deg);
}

.green-balloon {
  width: 112rpx;
  height: 152rpx;
  right: 38rpx;
  top: 74rpx;
  background: #24c45a;
  transform: rotate(16deg);
}

.play-button {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 88rpx;
  height: 88rpx;
  margin-left: -44rpx;
  margin-top: -44rpx;
  border-radius: 50%;
  background: rgba(255,255,255,.94);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 22rpx rgba(0,0,0,.16);
}

.play-triangle {
  width: 0;
  height: 0;
  margin-left: 8rpx;
  border-top: 17rpx solid transparent;
  border-bottom: 17rpx solid transparent;
  border-left: 27rpx solid #ba6b00;
}

.store-info {
  min-height: 100rpx;
  padding: 22rpx 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.store-name {
  display: block;
  color: #111111;
  font-size: 30rpx;
  font-weight: 900;
}

.store-address {
  margin-top: 10rpx;
  color: #777777;
  font-size: 22rpx;
}

.score {
  color: #f29b00;
  font-size: 22rpx;
  font-weight: 900;
}

.tabbar {
  position: fixed;
  z-index: 20;
  left: 0;
  right: 0;
  bottom: 0;
  height: 122rpx;
  padding: 12rpx 82rpx 18rpx;
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  background: #fff3e8;
  display: flex;
  justify-content: space-between;
  box-shadow: 0 -10rpx 32rpx rgba(132, 60, 0, .13);
}

.tab-item {
  width: 98rpx;
  height: 90rpx;
  border-radius: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #898989;
  font-size: 20rpx;
  font-weight: 800;
}

.tab-item.active {
  background: #ff8a00;
  color: #ffffff;
}

.tab-icon {
  position: relative;
  width: 30rpx;
  height: 30rpx;
}

.tab-icon.home {
  background: currentColor;
  clip-path: polygon(50% 0, 100% 42%, 88% 42%, 88% 100%, 62% 100%, 62% 66%, 38% 66%, 38% 100%, 12% 100%, 12% 42%, 0 42%);
}

.tab-icon.shop {
  border: 4rpx solid currentColor;
  border-radius: 5rpx 5rpx 8rpx 8rpx;
}

.tab-icon.shop::before {
  content: '';
  position: absolute;
  left: -4rpx;
  right: -4rpx;
  top: -12rpx;
  height: 12rpx;
  border: 4rpx solid currentColor;
  border-bottom: none;
  border-radius: 8rpx 8rpx 0 0;
}

.tab-icon.mine {
  border-radius: 50%;
  background: currentColor;
}

.tab-icon.mine::after {
  content: '';
  position: absolute;
  left: -8rpx;
  right: -8rpx;
  bottom: -22rpx;
  height: 26rpx;
  border-radius: 20rpx 20rpx 4rpx 4rpx;
  background: currentColor;
}
