.home-page {
  min-height: 100vh;
  padding-bottom: 136rpx;
  background:
    radial-gradient(circle at 14% 26%, rgba(255, 186, 37, 0.18) 0 54rpx, transparent 56rpx),
    radial-gradient(circle at 82% 46%, rgba(255, 185, 32, 0.16) 0 72rpx, transparent 74rpx),
    linear-gradient(180deg, #ffffff 0 208rpx, #ff7d05 208rpx 100%);
}

.top-panel {
  height: 214rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 22rpx;
  background: #ffffff;
  border-bottom-left-radius: 42rpx;
  border-bottom-right-radius: 42rpx;
}

.brand-logo { width: 360rpx; }

.main-shell {
  margin-top: -6rpx;
  padding: 0 24rpx;
}

.hero-card {
  background: #ffffff;
  border-radius: 34rpx;
  padding: 22rpx 20rpx 28rpx;
  box-shadow: 0 18rpx 40rpx rgba(128, 55, 0, 0.14);
}

.hero-banner {
  width: 100%;
  height: 286rpx;
  border-radius: 28rpx;
  display: block;
}

.entry-row {
  display: flex;
  justify-content: space-between;
  padding-top: 26rpx;
}

.entry-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.entry-image {
  width: 124rpx;
  height: 124rpx;
}

.entry-label {
  margin-top: 10rpx;
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 600;
  color: #222222;
}

.intro-section {
  position: relative;
  margin-top: 24rpx;
  padding-bottom: 24rpx;
}

.intro-section::before,
.intro-section::after {
  content: '';
  position: absolute;
  background: rgba(255, 173, 61, 0.16);
  border-radius: 50%;
}

.intro-section::before {
  width: 160rpx;
  height: 160rpx;
  right: 10rpx;
  top: 80rpx;
}

.intro-section::after {
  width: 96rpx;
  height: 96rpx;
  left: 18rpx;
  bottom: 18rpx;
}

.section-title {
  position: relative;
  z-index: 1;
  display: block;
  padding: 4rpx 0 18rpx;
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #ffffff;
}

.intro-card {
  position: relative;
  z-index: 1;
  background: #ffffff;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 42rpx rgba(128, 55, 0, 0.14);
}

.cover-wrap {
  position: relative;
  width: 100%;
  height: 336rpx;
}

.store-cover {
  width: 100%;
  height: 100%;
  display: block;
}

.play-button {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 92rpx;
  height: 92rpx;
  margin-left: -46rpx;
  margin-top: -46rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.18);
}

.play-triangle {
  width: 0;
  height: 0;
  margin-left: 8rpx;
  border-top: 18rpx solid transparent;
  border-bottom: 18rpx solid transparent;
  border-left: 28rpx solid #a96a00;
}

.store-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 24rpx 26rpx;
}

.store-meta { display: flex; flex-direction: column; }
.store-name { font-size: 33rpx; font-weight: 700; color: #1d1d1f; }
.store-address { margin-top: 10rpx; font-size: 22rpx; color: #7f7f86; }
.store-score { font-size: 24rpx; font-weight: 700; color: #f2a106; }

.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 118rpx;
  background: rgba(255, 255, 255, 0.98);
  border-top-left-radius: 34rpx;
  border-top-right-radius: 34rpx;
  box-shadow: 0 -8rpx 30rpx rgba(80, 54, 14, 0.08);
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.tab-item {
  width: 120rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #a0a0a3;
  font-size: 22rpx;
  font-weight: 600;
}

.tab-item.active { color: #ffffff; background: #ff9a10; }
.tab-icon { position: relative; width: 32rpx; height: 32rpx; margin-bottom: 6rpx; }
.tab-icon.home { background: currentColor; clip-path: polygon(50% 0, 100% 40%, 87% 40%, 87% 100%, 61% 100%, 61% 66%, 39% 66%, 39% 100%, 13% 100%, 13% 40%, 0 40%); }
.tab-icon.shop { border: 4rpx solid currentColor; border-radius: 5rpx 5rpx 8rpx 8rpx; }
.tab-icon.shop::before { content: ''; position: absolute; left: -4rpx; right: -4rpx; top: -12rpx; height: 12rpx; border: 4rpx solid currentColor; border-bottom: none; border-radius: 8rpx 8rpx 0 0; }
.tab-icon.mine { border-radius: 50%; background: currentColor; }
.tab-icon.mine::after { content: ''; position: absolute; left: -8rpx; right: -8rpx; bottom: -20rpx; height: 24rpx; border-radius: 20rpx 20rpx 4rpx 4rpx; background: currentColor; }
