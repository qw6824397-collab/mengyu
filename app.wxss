page {
  min-height: 100vh;
  background: #ff7a00;
  color: #1f1f1f;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

view,
text,
image,
button {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  line-height: 1;
}

button::after {
  border: none;
}
